<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_next_session_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_vertical"
        android:background="@drawable/widget_card_bg"
        android:padding="14dp">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NEXT SESSION"
            android:textColor="#71717a"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.15"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/widget_session_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ninguna sesión hoy"
            android:textColor="#18181b"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:ellipsize="end"
            android:maxLines="1" />

        <TextView
            android:id="@+id/widget_program_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tu Programa"
            android:textColor="#71717a"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:layout_marginTop="2dp" />
    </LinearLayout>
</FrameLayout>
