<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_nutrition_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_vertical"
        android:background="@drawable/widget_card_bg"
        android:padding="14dp">

        <TextView
            android:id="@+id/widget_nutrition_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NUTRITION"
            android:textColor="#71717a"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.15"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/widget_calories_main"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 / 0 kcal"
            android:textColor="#18181b"
            android:textSize="15sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/widget_macro_cell"
                android:padding="6dp"
                android:layout_marginEnd="4dp">
                <TextView
                    android:id="@+id/widget_protein_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#3b82f6"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="P"
                    android:textColor="#71717a"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:layout_marginTop="1dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/widget_macro_cell"
                android:padding="6dp"
                android:layout_marginHorizontal="2dp">
                <TextView
                    android:id="@+id/widget_carbs_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#22c55e"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="C"
                    android:textColor="#71717a"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:layout_marginTop="1dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/widget_macro_cell"
                android:padding="6dp"
                android:layout_marginStart="4dp">
                <TextView
                    android:id="@+id/widget_fats_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#f59e0b"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="G"
                    android:textColor="#71717a"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:layout_marginTop="1dp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
